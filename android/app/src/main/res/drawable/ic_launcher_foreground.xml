<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Circle outline -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="2.8"
        android:fillColor="#00000000"
        android:pathData="M54,7 A47,47 0 1,0 54,101 A47,47 0 1,0 54,7"/>

    <!-- Top half: filled outline using evenOdd so all corners are geometrically
         closed (no stroke miter artifacts). Outer diamond expands ~4 units out
         from the center path; inner diamond contracts ~4 units in. -->
    <path
        android:fillColor="#000000"
        android:fillType="evenOdd"
        android:pathData="M27,16 L54,29 L81,16 L54,59 Z M33,22 L54,37 L75,22 L54,51 Z"/>

    <!-- Bottom half: identical shape to top half, mirrored vertically, filled solid. -->
    <path
        android:fillColor="#000000"
        android:pathData="M27,92 L54,79 L81,92 L54,49 Z"/>

</vector>
